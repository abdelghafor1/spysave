{
  "manifest_version": 3,
  "name": "SpySave",
  "short_name": "SpySave",
  "description": "Save Meta, Facebook, and TikTok Creative Center ads to your SpySave dashboard for AI analysis.",
  "version": "0.3.2",
  "browser_specific_settings": {
    "gecko": {
      "id": "spysave@spysave.app",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "SpySave - Save ad",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://spysave.vercel.app/*",
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://ads.tiktok.com/*",
    "https://www.tiktok.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://spysave.vercel.app/*"],
      "js": ["site-bridge.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*",
        "https://ads.tiktok.com/*",
        "https://www.tiktok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
